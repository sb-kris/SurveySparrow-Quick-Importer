# Weave runs entirely on these few env vars. None are strictly required —
# every key has a sensible default. Copy this file to .env to customise.

# Port the server listens on. The same port serves both the HTML UI at /
# and the /api/* routes. Render and most PaaS providers inject PORT
# automatically, so you usually don't need to set it in production.
PORT=3001

# Set to "production" when deploying. In development, pino-pretty colorises
# the logs; in production, logs are emitted as raw JSON for log aggregators.
NODE_ENV=development

# Optional pino log level: trace | debug | info | warn | error | fatal.
LOG_LEVEL=info
